# Root .gitignore for Crypto Analytics (FastAPI + React)

# Environment variables (CRITICAL: Do not push these)
.env
.env.local
.env.*.local
*.env
.venv/
venv/
env/

# Python / FastAPI
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/
*.db
*.sqlite3

# Node.js / React (frondend)
node_modules/
frondend/node_modules/
dist/
frondend/dist/
dist-ssr/
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# OS / IDE
.DS_Store
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
